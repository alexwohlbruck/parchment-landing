{
  "name": "parchment-landing",
  "packageManager": "bun@1.2.14",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "nuxt dev",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "nuxt typecheck",
    "build:globe": "SIZE_W=2048 SIZE_H=1024 ./scripts/build-globe-textures.sh && BRIGHT=1.18 SAT=1.28 POSTERIZE=6 node ./scripts/postprocess-globe.js",
    "build:globe:4k": "SIZE_W=4096 SIZE_H=2048 ./scripts/build-globe-textures.sh && BRIGHT=1.12 SAT=1.18 POSTERIZE=4 node ./scripts/postprocess-globe.js",
    "build:globe:std": "COLORS_FILE=./scripts/colors-standard.txt SIZE_W=2048 SIZE_H=1024 ./scripts/build-globe-textures.sh && node ./scripts/postprocess-globe.js",
    "build:albedo:mapbox": "./scripts/render-mapbox-albedo.sh"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^13.6.0",
    "@vueuse/motion": "^2.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.539.0",
    "mbgl-renderer": "^0.9.0",
    "nuxt": "^4.0.1",
    "reka-ui": "^2.4.1",
    "shadcn-nuxt": "2.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "three": "0.161",
    "tw-animate-css": "^1.3.6",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vue-sonner": "^2.0.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/three": "^0.179.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.11.1",
    "pngjs": "^7.0.0",
    "vitest": "^4.1.10"
  }
}